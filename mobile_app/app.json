{
  "expo": {
    "name": "Security Cam",
    "slug": "security-cam-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111111"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "package": "com.durjavnicite.securitycamapp"
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00aaff",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c6876c4d-0eaa-469a-835f-7f14a6b15f65"
      }
    }
  }
}
